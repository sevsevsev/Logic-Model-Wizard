{
  "name": "lm-chatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:guardrails": "tsx --test src/lib/chat/guardrails.test.ts",
    "test:impact-draft-reply": "tsx --test src/lib/chat/impactDraftReply.test.ts",
    "test:agent-scenarios": "tsx scripts/agent-regression.ts",
    "test:incident-taxonomy": "tsx --test src/lib/regression/incidents.test.ts",
    "test:candidate-templates": "tsx --test src/lib/regression/candidates.test.ts",
    "test:unattended-loop": "tsx --test src/lib/regression/unattended.test.ts",
    "collect:incidents": "tsx scripts/agent-incident-loop.ts --mode collect",
    "generate:candidates": "tsx scripts/agent-generate-candidates.ts",
    "run:candidates": "tsx scripts/agent-run-candidates.ts",
    "qa:dashboard": "tsx scripts/agent-qa-dashboard.ts",
    "run:unattended-loop": "tsx scripts/agent-unattended-loop.ts",
    "workspace:clean": "powershell -ExecutionPolicy Bypass -File scripts/local-workspace-clean.ps1",
    "workspace:clean:apply": "powershell -ExecutionPolicy Bypass -File scripts/local-workspace-clean.ps1 -Apply",
    "rag:ingest": "tsx --env-file .env.local scripts/rag/ingest-knowledge.ts",
    "rag:ingest-export": "tsx --env-file .env.local scripts/rag/ingest-from-export.ts",
    "rag:ingest-schools": "tsx --env-file .env.local scripts/rag/ingest-schools-csv.ts",
    "rag:reset-table": "tsx --env-file .env.local scripts/rag/reset-vector-table.ts",
    "rag:list": "tsx --env-file .env.local scripts/rag/list-chunks.ts"
  },
  "dependencies": {
    "immer": "^11.1.4",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.12.0",
    "next": "^15.3.2",
    "pdf2json": "^4.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.6",
    "@types/node": "^22.0.0",
    "@types/pdfjs-dist": "^2.10.377",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "tailwindcss": "^4.1.6",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
