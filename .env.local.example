# Gemini API Key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Response chips are currently deprecated by default.
# Set true only when intentionally testing chip UX behavior.
ENABLE_RESPONSE_CHIPS=false

# Keep prompt payload compact by default for better instruction adherence.
# Set true only when running full-reference prompt experiments.
FULL_KNOWLEDGE_BASE_PROMPT=false

# Agentic orchestration flag (Phase A).
# When false, route uses legacy deterministic pipeline only.
ENABLE_AGENTIC_TURN=false

# Dual-run mode executes agentic turn for comparison logs while serving legacy response.
AGENTIC_DUAL_RUN=false

# Retrieval mode: vector retrieval is enabled by default.
# Set false only to force keyword-only fallback mode.
# ENABLE_RAG_RETRIEVAL=false

# Retrieval depth tuning for stronger inference (higher values = broader context, higher cost/latency).
# RAG_LEGACY_TOP_K=8
# RAG_AGENT_USER_TOP_K=8
# RAG_AGENT_PLAN_TOP_K=6
# RAG_AGENT_MERGED_TOP_K=12

# Persistent storage for drafts + feedback + debug reports (recommended in production)
# Example: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Optional local JSON path override when DATABASE_URL is not set.
# CLOUD_DRAFT_DB_PATH=.data/cloud-drafts.json
