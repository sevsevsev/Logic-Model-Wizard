# Gemini API Key — get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Persistent storage for drafts + feedback + debug reports (recommended in production)
# Example: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# Optional local JSON path override when DATABASE_URL is not set.
